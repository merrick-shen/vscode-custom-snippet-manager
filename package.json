{
  "name": "custom-snippet-manager",
  "displayName": "Custom Snippet Manager",
  "description": "A VS Code extension for managing custom code snippets with a modern webview UI",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "custom-snippet-manager",
          "title": "Custom Snippet Manager",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "custom-snippet-manager": [
        {
          "type": "webview",
          "id": "custom-snippet-manager.sidebar",
          "name": "Snippets",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "custom-snippet-manager.openEditor",
        "title": "New Snippet",
        "icon": "$(add)"
      },
      {
        "command": "custom-snippet-manager.openSnippetLibrary",
        "title": "Open Snippet Library"
      },
      {
        "command": "custom-snippet-manager.insertSnippet",
        "title": "Insert Snippet"
      },
      {
        "command": "custom-snippet-manager.triggerCompletion",
        "title": "Trigger Snippet Completion"
      }
    ],
    "keybindings": [
      {
        "command": "custom-snippet-manager.insertSnippet",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus"
      },
      {
        "command": "custom-snippet-manager.triggerCompletion",
        "key": "ctrl+alt+space",
        "mac": "cmd+alt+space",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "custom-snippet-manager.insertSnippet",
          "when": "editorTextFocus",
          "group": "snippet@1"
        }
      ],
      "commandPalette": [
        {
          "command": "custom-snippet-manager.openEditor",
          "when": "true"
        },
        {
          "command": "custom-snippet-manager.openSnippetLibrary",
          "when": "true"
        },
        {
          "command": "custom-snippet-manager.insertSnippet",
          "when": "editorTextFocus"
        },
        {
          "command": "custom-snippet-manager.triggerCompletion",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "build:webview": "cd webview && npm run build",
    "compile:all": "npm run build:webview && npm run compile",
    "package:all": "npm run build:webview && npm run package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
