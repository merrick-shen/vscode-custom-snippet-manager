{
  "name": "custom-snippet-manager",
  "displayName": "Custom Snippet Manager - 自定义片段管理器",
  "description": "Manage and use custom code snippets | 管理和使用自定义代码片段",
  "version": "1.3.0",
  "engines": {
    "vscode": "^1.116.0"
  },
  "publisher": "Horyce",
  "author": {
    "name": "Horyce",
    "email": "smh070912@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/horyce/vscode-custom-snippet-manager"
  },
  "homepage": "https://github.com/horyce/vscode-custom-snippet-manager#readme",
  "bugs": {
    "url": "https://github.com/horyce/vscode-custom-snippet-manager/issues"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "vscode extension",
    "snippet extension",
    "vscode snippet",
    "snippet tool",
    "code generator",
    "developer productivity",
    "snippet",
    "snippets",
    "code snippet",
    "code snippets",
    "snippet manager",
    "snippets manager",
    "snippet library",
    "code library",
    "code templates",
    "template",
    "autocomplete",
    "intellisense",
    "productivity",
    "developer tools",
    "代码片段",
    "代码模板",
    "代码库"
  ],
  "activationEvents": [
    "onView:custom-snippet-manager.sidebar",
    "onCommand:custom-snippet-manager.openSnippetLibrary",
    "onCommand:custom-snippet-manager.insertSnippet",
    "onCommand:custom-snippet-manager.triggerCompletion",
    "onCommand:custom-snippet-manager.saveSelectionToSnippet",
    "onCommand:custom-snippet-manager.openEditor"
  ],
  "main": "./dist/extension.js",
  "icon": "resources/logo.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "custom-snippet-manager",
          "title": "%viewsContainers.activitybar.title%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "custom-snippet-manager": [
        {
          "type": "webview",
          "id": "custom-snippet-manager.sidebar",
          "name": "%views.sidebar.name%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "custom-snippet-manager.openEditor",
        "title": "%command.openEditor.title%",
        "icon": "$(add)"
      },
      {
        "command": "custom-snippet-manager.openSnippetLibrary",
        "title": "%command.openSnippetLibrary.title%"
      },
      {
        "command": "custom-snippet-manager.insertSnippet",
        "title": "%command.insertSnippet.title%"
      },
      {
        "command": "custom-snippet-manager.triggerCompletion",
        "title": "%command.triggerCompletion.title%"
      },
      {
        "command": "custom-snippet-manager.saveSelectionToSnippet",
        "title": "%command.saveSelectionToSnippet.title%"
      }
    ],
    "keybindings": [
      {
        "command": "custom-snippet-manager.insertSnippet",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus"
      },
      {
        "command": "custom-snippet-manager.triggerCompletion",
        "key": "ctrl+alt+space",
        "mac": "cmd+alt+space",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "custom-snippet-manager.insertSnippet",
          "when": "editorTextFocus",
          "group": "snippet@1"
        },
        {
          "command": "custom-snippet-manager.saveSelectionToSnippet",
          "when": "editorHasSelection",
          "group": "snippet@2"
        }
      ],
      "commandPalette": [
        {
          "command": "custom-snippet-manager.openEditor",
          "when": "true"
        },
        {
          "command": "custom-snippet-manager.openSnippetLibrary",
          "when": "true"
        },
        {
          "command": "custom-snippet-manager.insertSnippet",
          "when": "editorTextFocus"
        },
        {
          "command": "custom-snippet-manager.triggerCompletion",
          "when": "editorTextFocus"
        },
        {
          "command": "custom-snippet-manager.saveSelectionToSnippet",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package:all",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "build:webview": "cd webview && npm run build",
    "compile:all": "npm run build:webview && npm run compile",
    "package:all": "npm run build:webview && npm run package",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "archiver": "^5.3.2"
  }
}
