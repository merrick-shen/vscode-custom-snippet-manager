{
  "name": "custom-snippet-manager",
  "displayName": "Custom Snippet Manager - 自定义片段管理器",
  "description": "Manage custom code snippets with ease. Create, edit, and organize your snippets with a modern UI, smart autocomplete, and multi-language support. | 轻松管理自定义代码片段，支持创建、编辑和组织片段，提供现代化界面、智能补全和多语言支持。",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.116.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/horyce/vscode-custom-snippet-manager"
  },
  "homepage": "https://github.com/horyce/vscode-custom-snippet-manager#readme",
  "bugs": {
    "url": "https://github.com/horyce/vscode-custom-snippet-manager/issues"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "keywords": [
    "snippet",
    "snippets",
    "code snippet",
    "code snippets",
    "snippet manager",
    "snippets manager",
    "snippet library",
    "code library",
    "code templates",
    "template",
    "autocomplete",
    "intellisense",
    "productivity",
    "developer tools",
    "代码片段",
    "代码模板",
    "代码库"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "resources/logo.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "custom-snippet-manager",
          "title": "Custom Snippet Manager",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "custom-snippet-manager": [
        {
          "type": "webview",
          "id": "custom-snippet-manager.sidebar",
          "name": "Snippets",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "custom-snippet-manager.openEditor",
        "title": "New Snippet",
        "icon": "$(add)"
      },
      {
        "command": "custom-snippet-manager.openSnippetLibrary",
        "title": "Open Snippet Library"
      },
      {
        "command": "custom-snippet-manager.insertSnippet",
        "title": "Insert Snippet"
      },
      {
        "command": "custom-snippet-manager.triggerCompletion",
        "title": "Trigger Snippet Completion"
      }
    ],
    "keybindings": [
      {
        "command": "custom-snippet-manager.insertSnippet",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus"
      },
      {
        "command": "custom-snippet-manager.triggerCompletion",
        "key": "ctrl+alt+space",
        "mac": "cmd+alt+space",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "custom-snippet-manager.insertSnippet",
          "when": "editorTextFocus",
          "group": "snippet@1"
        }
      ],
      "commandPalette": [
        {
          "command": "custom-snippet-manager.openEditor",
          "when": "true"
        },
        {
          "command": "custom-snippet-manager.openSnippetLibrary",
          "when": "true"
        },
        {
          "command": "custom-snippet-manager.insertSnippet",
          "when": "editorTextFocus"
        },
        {
          "command": "custom-snippet-manager.triggerCompletion",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "build:webview": "cd webview && npm run build",
    "compile:all": "npm run build:webview && npm run compile",
    "package:all": "npm run build:webview && npm run package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
