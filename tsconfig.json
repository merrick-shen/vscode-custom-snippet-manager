{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"resolveJsonModule": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*", "locales.json"],
	"exclude": ["webview", "node_modules", "out", "dist"]
}
